{
  "$schema": "https://github.com/glzr-io/zebar/raw/v3.0.0/resources/zpack-schema.json",
  "name": "simple-ws",
  "version": "1.0.0",
  "description": "Minimal workspace-only widget for GlazeWM.",
  "tags": ["topbar"],
  "widgets": [
    {
      "name": "workspaces",
      "htmlPath": "./index.html",
      "zOrder": "bottom_most",
      "shownInTaskbar": false,
      "focused": false,
      "resizable": false,
      "transparent": true,
      "includeFiles": ["*.html", "*.css", "app-bundle.js"],
      "presets": [
        {
          "name": "default",
          "anchor": "top_center",
          "offsetX": "0px",
          "offsetY": "0px",
          "width": "100%",
          "height": "40px",
          "monitorSelection": { "type": "all" }
        }
      ]
    }
  ]
}
